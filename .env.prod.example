DOMAIN=example.com

POSTGRES_DB=ibergrid
POSTGRES_USER=ibergrid
POSTGRES_PASSWORD=change-this-password

IBERGRID_MLFLOW_EXPERIMENT_NAME=ibergrid-production
IBERGRID_HORIZON_HOURS=168
IBERGRID_ENCODER_HOURS=336
IBERGRID_RETRAIN_BATCH_SIZE=64
IBERGRID_RETRAIN_NUM_WORKERS=2
IBERGRID_RETRAIN_EPOCHS=8

IBERGRID_WORKER_REFRESH_DAYS=30
IBERGRID_WORKER_BACKFILL_YEARS=2
IBERGRID_WORKER_RECONCILIATION_DAYS=14
IBERGRID_WORKER_DAILY_JOB_HOUR=7
IBERGRID_WORKER_DAILY_JOB_MINUTE=10
IBERGRID_WORKER_WEEKLY_JOB_DAY_OF_WEEK=sun
IBERGRID_WORKER_WEEKLY_JOB_HOUR=5
IBERGRID_WORKER_WEEKLY_JOB_MINUTE=30
IBERGRID_WORKER_RECONCILIATION_JOB_HOUR=6
IBERGRID_WORKER_RECONCILIATION_JOB_MINUTE=45

# Leave empty to use same-origin `/api/*` behind Caddy.
NEXT_PUBLIC_API_BASE_URL=
